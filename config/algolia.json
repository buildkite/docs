{
  "index_name": "prod_docs",
  "start_urls": [
    {
      "url": "https://buildkite.com/docs/pipelines",
      "selectors_key": "default",
      "tags": ["docs", "pipelines"]
    },
    {
      "url": "https://buildkite.com/docs/agent",
      "selectors_key": "default",
      "tags": ["docs", "agent"]
    },
    {
      "url": "https://buildkite.com/docs/test-engine",
      "selectors_key": "default",
      "tags": ["docs", "test-engine"]
    },
    {
      "url": "https://buildkite.com/docs/package-registries",
      "selectors_key": "default",
      "tags": ["docs", "package-registries"]
    },
    {
      "url": "https://buildkite.com/docs/platform",
      "selectors_key": "default",
      "tags": ["docs", "platform"]
    },
    {
      "url": "https://buildkite.com/docs/apis",
      "selectors_key": "default",
      "tags": ["docs", "apis"]
    },
    {
      "url": "https://buildkite.com/resources/plugins/",
      "selectors_key": "plugins",
      "tags": ["plugin"]
    },
    {
      "url": "https://buildkite.com/resources/changelog/",
      "selectors_key": "changelog",
      "tags": ["changelog"]
    },
    {
      "url": "https://buildkite.com/resources/blog/",
      "selectors_key": "blog",
      "tags": ["blog"]
    }
  ],
  "stop_urls": [
    "docs/sdk/python",
    "docs/sdk/typescript",
    "docs/sdk/ruby",
    "resources/changelog/tag/",
    "resources/blog/tag/"
  ],
  "selectors": {
    "default": {
      "lvl0": {
        "selector": ".SiteHeader__nav .Nav__link.Nav__link--level1.Nav__link--current",
        "global": true
      },
      "lvl1": ".Article h1",
      "lvl2": ".Article h2",
      "lvl3": ".Article h3",
      "lvl4": ".Article h4, .Article th",
      "lvl5": ".Article h5, .Article td:first-child",
      "text": ".Article p, .Article li, .Article td"
    },
    "plugins": {
      "lvl0": {
        "selector": "",
        "default_value": "Plugins",
        "global": true
      },
      "lvl1": "#main-content h1",
      "lvl2": "#main-content h2",
      "lvl3": "#main-content h3",
      "lvl4": "#main-content h4",
      "text": "#main-content p, #main-content li"
    },
    "changelog": {
      "lvl0": {
        "selector": "",
        "default_value": "Changelog",
        "global": true
      },
      "lvl1": "#main-content h1",
      "lvl2": "#main-content h2",
      "lvl3": "#main-content h3",
      "text": "#main-content p, #main-content li"
    },
    "blog": {
      "lvl0": {
        "selector": "",
        "default_value": "Blog",
        "global": true
      },
      "lvl1": "#main-content h1",
      "lvl2": "#main-content article.prose h2",
      "lvl3": "#main-content article.prose h3",
      "text": "#main-content article.prose p, #main-content article.prose li"
    }
  },
  "selectors_exclude": [
    "[data-algolia-exclude]",
    ".Toc",
    ".Footer",
    "footer",
    ".Page__sidebar",
    ".Nav__section--level2"
  ],
  "custom_settings": {
    "synonyms": [["Pipeline.yml", "Pipeline.yaml", "config.yml", "config.yaml"], ["k8s", "kubernetes"], ["gcp", "google cloud provider"], ["aws", "amazon web services"], ["cli", "command line interface", "command line reference"], ["plugin", "plug in"], ["if changed", "if_changed"], ["app", "application"], ["monorepo diff", "monorepo_diff"], ["env", "environment"], ["var", "variable"], ["llm", "large language model"], ["sla", "service level agreement"], ["mcp", "model context provider"]],
    "ranking": ["words", "typo", "attribute", "proximity", "filters", "exact", "custom"],
    "attributesForFaceting": ["tags"],
    "customRanking": ["desc(weight.page_rank)", "desc(importance)", "desc(weight.level)", "asc(weight.position)"]
  }
}
