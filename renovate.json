{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "prConcurrentLimit": 3,
    "packageRules": [
        {
            "groupName": "Ruby version",
            "matchDepNames": ["ruby"],
            "matchDatasources": ["docker", "ruby-version"]
        },
        {
            "groupName": "npm packages",
            "matchManagers": ["npm"]
        },
        {
            "groupName": "Ruby gems",
            "matchManagers": ["bundler"],
            "matchDepNames": ["!ruby"]
        },
        {
            "groupName": "Docker images",
            "matchDatasources": ["docker"],
            "matchDepNames": ["!ruby"]
        }
    ]
}
