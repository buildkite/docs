{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "prConcurrentLimit": 3,
    "packageRules": [
        {
            "groupName": "npm packages",
            "matchManagers": ["npm"]
        },
        {
            "groupName": "Ruby gems",
            "matchManagers": ["bundler"]
        },
        {
            "groupName": "Docker images",
            "matchDatasources": ["docker"]
        }
    ]
}
