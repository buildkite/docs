<%
  nav_level = nav_level + 1
  ul_classes = type == "dropdown" ? "Nav__dropdown" : "Nav__section Nav__section--level#{nav_level}"
  ul_classes += " Nav__section--show" if start_expanded
-%>
<ul class="<%= ul_classes %>">
<% children.each do |child| -%>
<% if child["type"] == "divider" -%>
<li class="Nav__item"><hr class="Nav__divider" /></li>
<% else -%>
<% li_classes = "Nav__item Nav__item--level#{nav_level}"
   li_classes += " Nav__item--has-dropdown" if child["type"] == "dropdown" -%>
<li class="<%= li_classes %>"><%= render "nav_link",
  name: child["name"],
  path: child["path"],
  current: current_nav_item && (current_nav_item[:path] == child["path"] || current_nav_item[:parents].include?(child["name"])),
  nav_level: nav_level,
  new_window: child["new_window"],
  pill: child["pill"],
  is_dropdown: child["is_dropdown"],
  start_expanded: current_nav_item && current_nav_item[:parents].include?(child["name"]) || child["start_expanded"],
  type: child["type"]
%><% if child["children"] && nav_level < 8 %><%= render "nav_children",
  children: child["children"],
  current_nav_item: current_nav_item,
  is_dropdown: child["is_dropdown"],
  nav_level: nav_level,
  start_expanded: current_nav_item && current_nav_item[:parents].include?(child["name"]) || child["start_expanded"],
  type: child["type"]
%><% end %></li>
<% end -%>
<% end -%>
</ul>
